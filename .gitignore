# ── 数据集 & 大文件 ────────────────────────────────────────────
data/*

# 论文 PDF（参考资料，非项目产出，本地留存）
*.pdf

# 模型权重（work_dirs 下的 ckpt 不进 git，单独分发）
work_dirs*/
ckpt/*.ckpt
ckpt/*.pth
ckpt/*.pt
ckpt/*.bin

# ── 输出目录（保留 .gitkeep，忽略其余内容） ────────────────────
results/*
!results/.gitkeep

demo/*
!demo/.gitkeep

# ── Python 缓存 ────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.eggs/
dist/
build/

# ── 日志 & 临时文件 ────────────────────────────────────────────
*.log
nohup.out
*.pid

# ── 媒体输出 ───────────────────────────────────────────────────
*.mp4
*.avi
*.mkv

# ── Pickle / 大型二进制 ────────────────────────────────────────
*.pkl
*.npy
*.npz

# ── IDE / 本机配置 ─────────────────────────────────────────────
.vscode/
.idea/
.claude/settings.local.json
